---
import "../styles/global.css";
import SpeedInsights from "@vercel/speed-insights/astro";

// Fontes críticas — preload elimina CLS e melhora LCP
import bebasNeueWoff2 from "@fontsource/bebas-neue/files/bebas-neue-latin-400-normal.woff2?url";
import barlowC700Woff2 from "@fontsource/barlow-condensed/files/barlow-condensed-latin-700-normal.woff2?url";
import barlowC400Woff2 from "@fontsource/barlow-condensed/files/barlow-condensed-latin-400-normal.woff2?url";
import barlowC300Woff2 from "@fontsource/barlow-condensed/files/barlow-condensed-latin-300-normal.woff2?url";
import barlowC500Woff2 from "@fontsource/barlow-condensed/files/barlow-condensed-latin-500-normal.woff2?url";
import barlowC600Woff2 from "@fontsource/barlow-condensed/files/barlow-condensed-latin-600-normal.woff2?url";
import outfitWoff2 from "@fontsource/outfit/files/outfit-latin-400-normal.woff2?url";
import outfit300Woff2 from "@fontsource/outfit/files/outfit-latin-300-normal.woff2?url";
import outfit500Woff2 from "@fontsource/outfit/files/outfit-latin-500-normal.woff2?url";
import outfit600Woff2 from "@fontsource/outfit/files/outfit-latin-600-normal.woff2?url";

const fontFaceCSS = `
@font-face{font-family:"Bebas Neue";font-style:normal;font-weight:400;font-display:optional;src:url(${bebasNeueWoff2}) format('woff2')}
@font-face{font-family:"Barlow Condensed";font-style:normal;font-weight:300;font-display:optional;src:url(${barlowC300Woff2}) format('woff2')}
@font-face{font-family:"Barlow Condensed";font-style:normal;font-weight:400;font-display:optional;src:url(${barlowC400Woff2}) format('woff2')}
@font-face{font-family:"Barlow Condensed";font-style:normal;font-weight:500;font-display:optional;src:url(${barlowC500Woff2}) format('woff2')}
@font-face{font-family:"Barlow Condensed";font-style:normal;font-weight:600;font-display:optional;src:url(${barlowC600Woff2}) format('woff2')}
@font-face{font-family:"Barlow Condensed";font-style:normal;font-weight:700;font-display:optional;src:url(${barlowC700Woff2}) format('woff2')}
@font-face{font-family:"Outfit";font-style:normal;font-weight:300;font-display:optional;src:url(${outfit300Woff2}) format('woff2')}
@font-face{font-family:"Outfit";font-style:normal;font-weight:400;font-display:optional;src:url(${outfitWoff2}) format('woff2')}
@font-face{font-family:"Outfit";font-style:normal;font-weight:500;font-display:optional;src:url(${outfit500Woff2}) format('woff2')}
@font-face{font-family:"Outfit";font-style:normal;font-weight:600;font-display:optional;src:url(${outfit600Woff2}) format('woff2')}
`;

interface Props {
  title: string;
  description: string;
  canonical?: string;
  ogImage?: string;
  ogType?: string;
  pageSchema?: object[];
  breadcrumbs?: { name: string; url: string }[];
  bodyClass?: string;
  includeFaq?: boolean;
}

const {
  title,
  description,
  canonical = Astro.url.href,
  ogImage = "https://ruche.com.br/images/og-ruche.jpg",
  ogType = "website",
  pageSchema = [],
  breadcrumbs,
  bodyClass = "",
  includeFaq = false,
} = Astro.props;

const SITE = "https://ruche.com.br";

const schemas: object[] = [
  {
    "@context": "https://schema.org",
    "@type": ["Organization", "LocalBusiness"],
    "@id": `${SITE}/#organization`,
    name: "Ruche",
    url: SITE,
    logo: {
      "@type": "ImageObject",
      url: `${SITE}/images/logo.svg`,
      width: 200,
      height: 60,
    },
    description:
      "Agência de SEO especializada no setor alimentício: restaurantes, marcas de alimentos e indústria.",
    address: {
      "@type": "PostalAddress",
      addressLocality: "São Paulo",
      addressRegion: "SP",
      addressCountry: "BR",
    },
    contactPoint: {
      "@type": "ContactPoint",
      contactType: "customer service",
      availableLanguage: "Portuguese",
    },
    sameAs: [],
  },
  {
    "@context": "https://schema.org",
    "@type": "WebSite",
    "@id": `${SITE}/#website`,
    name: "Ruche: SEO Alimentício",
    url: SITE,
    publisher: { "@id": `${SITE}/#organization` },
    potentialAction: {
      "@type": "SearchAction",
      target: {
        "@type": "EntryPoint",
        urlTemplate: `${SITE}/blog?q={search_term_string}`,
      },
      "query-input": "required name=search_term_string",
    },
  },
];

if (breadcrumbs && breadcrumbs.length > 0) {
  schemas.push({
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    itemListElement: [
      { "@type": "ListItem", position: 1, name: "Início", item: SITE },
      ...breadcrumbs.map((b, i) => ({
        "@type": "ListItem",
        position: i + 2,
        name: b.name,
        item: b.url,
      })),
    ],
  });
}

if (includeFaq) {
  schemas.push({
    "@context": "https://schema.org",
    "@type": "FAQPage",
    mainEntity: [
      {
        "@type": "Question",
        name: "O que é SEO para o setor alimentício?",
        acceptedAnswer: {
          "@type": "Answer",
          text: "SEO alimentício é a otimização de presença digital específica para restaurantes, marcas de alimentos e indústria alimentícia, com estratégias focadas em buscas locais, intenção de compra e conteúdo especializado no segmento.",
        },
      },
      {
        "@type": "Question",
        name: "Quanto tempo leva para ver resultados de SEO?",
        acceptedAnswer: {
          "@type": "Answer",
          text: "Os primeiros resultados orgânicos significativos aparecem entre 3-6 meses. Com estratégia contínua, o crescimento se consolida nos 12 meses seguintes, gerando ROI comprovável e crescimento sustentável.",
        },
      },
      {
        "@type": "Question",
        name: "A Ruche atende todo o Brasil?",
        acceptedAnswer: {
          "@type": "Answer",
          text: "Sim, atendemos clientes em todo o território nacional com estratégias locais e nacionais customizadas para cada segmento do setor alimentício.",
        },
      },
    ],
  });
}

schemas.push(...pageSchema);
---

<!doctype html>
<html lang="pt-BR">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="theme-color" content="#040200" />
    <meta name="robots" content="index, follow" />

    <!-- Fontes: @font-face com font-display:optional → zero CLS -->
    <style set:html={fontFaceCSS}></style>

    <!-- Preload fontes críticas above-the-fold (Bebas Neue + Barlow 700) -->
    <link rel="preload" href={bebasNeueWoff2} as="font" type="font/woff2" crossorigin />
    <link rel="preload" href={barlowC700Woff2} as="font" type="font/woff2" crossorigin />

    <!-- SEO primário -->
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />

    <!-- Hreflang -->
    <link rel="alternate" hreflang="pt-BR" href={canonical} />
    <link rel="alternate" hreflang="x-default" href={canonical} />

    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:url" content={canonical} />
    <meta property="og:type" content={ogType} />
    <meta property="og:locale" content="pt_BR" />
    <meta property="og:site_name" content="Ruche: SEO Alimentício" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <!-- Schema.org JSON-LD -->
    {
      schemas.map((s) => (
        <script
          type="application/ld+json"
          set:html={JSON.stringify(s)}
        />
      ))
    }
  </head>
  <body class={bodyClass}>
    <a href="#main-content" class="skip-link">Pular para o conteúdo principal</a>
    <slot />
    <SpeedInsights />
  </body>
</html>

---
const WA =
  "https://wa.me/5511999999999?text=Ol%C3%A1%2C%20quero%20saber%20mais%20sobre%20SEO%20aliment%C3%ADcio";

const links = [
  { href: "/", label: "Início" },
  { href: "/quem-somos", label: "Quem Somos" },
  { href: "/blog", label: "Blog" },
  { href: "/contato", label: "Contato" },
];

const path = Astro.url.pathname.replace(/\/$/, "") || "/";
---

<header class="nav-header" id="nav-header" role="banner">
  <nav
    class="nav-container"
    aria-label="Navegação principal"
  >
    <!-- Logo -->
    <a href="/" class="nav-logo" aria-label="Ruche — Página inicial">
      <span class="nav-logo-hex" aria-hidden="true">
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="28"
          height="32"
          viewBox="0 0 28 32"
          fill="none"
        >
          <polygon
            points="14,1.5 27,8.5 27,23.5 14,30.5 1,23.5 1,8.5"
            fill="#EF9F27"
          ></polygon>
          <text
            x="14"
            y="21"
            text-anchor="middle"
            font-family="Arial Black,sans-serif"
            font-size="13"
            font-weight="900"
            fill="#040200"
          >R</text>
        </svg>
      </span>
      <span class="nav-logo-text">RUCHE</span>
    </a>

    <!-- Links desktop -->
    <ul class="nav-links" role="list">
      {
        links.map((link) => {
          const isActive =
            link.href === "/"
              ? path === "/"
              : path === link.href || path.startsWith(link.href + "/");
          return (
            <li>
              <a
                href={link.href}
                class={`nav-link${isActive ? " nav-link--active" : ""}`}
                aria-current={isActive ? "page" : undefined}
              >
                {link.label}
              </a>
            </li>
          );
        })
      }
    </ul>

    <!-- CTA desktop -->
    <a
      href={WA}
      class="btn btn-amber nav-cta"
      target="_blank"
      rel="noopener noreferrer"
      aria-label="Fale conosco no WhatsApp"
    >
      <svg
        xmlns="http://www.w3.org/2000/svg"
        width="16"
        height="16"
        viewBox="0 0 24 24"
        fill="currentColor"
        aria-hidden="true"
      >
        <path
          d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"
        ></path>
      </svg>
      WhatsApp
    </a>

    <!-- Hamburger mobile -->
    <button
      class="nav-hamburger"
      id="nav-hamburger"
      aria-expanded="false"
      aria-controls="nav-drawer"
      aria-label="Abrir menu de navegação"
    >
      <span class="hamburger-bar"></span>
      <span class="hamburger-bar"></span>
      <span class="hamburger-bar"></span>
    </button>
  </nav>
</header>

<!-- Mobile Drawer -->
<div
  class="nav-drawer"
  id="nav-drawer"
  role="dialog"
  aria-modal="true"
  aria-label="Menu de navegação"
>
  <button
    class="nav-drawer-close"
    id="nav-drawer-close"
    aria-label="Fechar menu"
  >
    ✕
  </button>
  <ul class="nav-drawer-links" role="list">
    {
      links.map((link) => {
        const isActive =
          link.href === "/"
            ? path === "/"
            : path === link.href || path.startsWith(link.href + "/");
        return (
          <li>
            <a
              href={link.href}
              class={`nav-drawer-link${isActive ? " nav-drawer-link--active" : ""}`}
            >
              {link.label}
            </a>
          </li>
        );
      })
    }
  </ul>
  <a
    href={WA}
    class="btn btn-amber"
    target="_blank"
    rel="noopener noreferrer"
    style="margin-top: 1rem;"
  >
    WhatsApp
  </a>
</div>

<script>
  const header = document.getElementById("nav-header")!;
  const hamburger = document.getElementById("nav-hamburger")!;
  const drawer = document.getElementById("nav-drawer")!;
  const closeBtn = document.getElementById("nav-drawer-close")!;

  // Scroll → blur
  const onScroll = () => {
    header.classList.toggle("nav-header--scrolled", window.scrollY > 60);
  };
  window.addEventListener("scroll", onScroll, { passive: true });
  onScroll();

  // Abrir drawer
  hamburger.addEventListener("click", () => {
    const open = drawer.classList.toggle("nav-drawer--open");
    hamburger.setAttribute("aria-expanded", String(open));
    document.body.style.overflow = open ? "hidden" : "";
  });

  // Fechar drawer
  const closeDrawer = () => {
    drawer.classList.remove("nav-drawer--open");
    hamburger.setAttribute("aria-expanded", "false");
    document.body.style.overflow = "";
  };

  closeBtn.addEventListener("click", closeDrawer);

  // Fechar ao clicar em link
  drawer.querySelectorAll(".nav-drawer-link").forEach((link) => {
    link.addEventListener("click", closeDrawer);
  });

  // Fechar com ESC
  document.addEventListener("keydown", (e) => {
    if (e.key === "Escape") closeDrawer();
  });
</script>

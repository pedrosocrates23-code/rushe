---
const WA =
  "https://wa.me/5561998642021?text=Ol%C3%A1%2C%20quero%20saber%20mais%20sobre%20SEO%20aliment%C3%ADcio";
---

<section class="hero" aria-labelledby="hero-title" id="hero">
  <!-- ── Light Pillar CSS ── zero JS, GPU-composited ── -->
  <div class="hero-pillar" aria-hidden="true">
    <!-- Raios côncicos girando (conic-gradient) -->
    <div class="hp-rays"></div>
    <!-- Coluna vertical central com blur -->
    <div class="hp-beam"></div>
    <!-- Núcleo brilhante estreito -->
    <div class="hp-core"></div>
    <!-- Halo de ambiente (radial) -->
    <div class="hp-glow"></div>
  </div>

  <!-- Overlay hex sutil -->
  <div
    class="hex-pattern"
    style="position:absolute;inset:0;opacity:0.3;pointer-events:none;z-index:2;"
    aria-hidden="true"
  >
  </div>

  <!-- Conteúdo -->
  <div class="hero-content" id="hero-content">
    <p class="eyebrow hero-eyebrow">Especialistas em SEO Alimentício</p>

    <h1 class="hero-title display" id="hero-title">
      Seu negócio<br />
      alimentício<br />
      <em>no topo do Google</em>
    </h1>

    <p class="hero-subtitle">
      Transformamos buscas em clientes. SEO estratégico para restaurantes,
      marcas e indústria alimentícia com resultado comprovado.
    </p>

    <div class="hero-actions">
      <a
        href={WA}
        class="btn btn-amber"
        target="_blank"
        rel="noopener noreferrer"
        aria-label="Falar com a Ruche pelo WhatsApp"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="18"
          height="18"
          viewBox="0 0 24 24"
          fill="currentColor"
          aria-hidden="true"
        >
          <path
            d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"
          ></path>
        </svg>
        Falar no WhatsApp
      </a>
      <a href="/quem-somos" class="btn btn-ghost">Conhecer a Ruche</a>
    </div>
  </div>

  <!-- Scroll indicator -->
  <div class="hero-scroll" aria-hidden="true">
    <div class="hero-scroll-bar"></div>
  </div>
</section>

<style>
  /* ── Light Pillar — CSS puro, GPU composited ─────────────── */
  .hero-pillar {
    position: absolute;
    inset: 0;
    overflow: hidden;
    pointer-events: none;
    z-index: 1;
  }

  /* Raios côncicos: conic-gradient girando a partir do rodapé central */
  .hp-rays {
    position: absolute;
    bottom: 0;
    left: 50%;
    /* Tamanho: 240% × 200% do hero → cobre toda a área ao girar */
    width: 240%;
    height: 200%;
    /* Ancora o ponto de emissão no bottom-center do hero */
    transform: translateX(-50%);
    transform-origin: 50% 100%;
    background: conic-gradient(
      from 0deg at 50% 100%,
      transparent           0deg,
      rgba(239,159,39,.07)  3deg,
      transparent          10deg,
      rgba(245,200,66,.05) 18deg,
      transparent          26deg,
      rgba(239,159,39,.06) 38deg,
      transparent          48deg,
      rgba(245,200,66,.04) 62deg,
      transparent          76deg,
      rgba(239,159,39,.05) 94deg,
      transparent         112deg,
      rgba(245,200,66,.03)128deg,
      transparent         145deg,
      rgba(239,159,39,.04)160deg,
      transparent         175deg,
      transparent         360deg
    );
    mix-blend-mode: screen;
    animation: hpRaysRotate 32s linear infinite;
    will-change: transform;
  }

  /* Coluna vertical central: blur intenso, pulsa */
  .hp-beam {
    position: absolute;
    top: 0;
    left: 50%;
    transform: translateX(-50%);
    width: clamp(70px, 10vw, 160px);
    height: 100%;
    background: linear-gradient(
      to bottom,
      transparent                   0%,
      rgba(245, 200, 66, 0.07)     8%,
      rgba(245, 200, 66, 0.22)    28%,
      rgba(239, 159, 39, 0.50)    48%,
      rgba(239, 159, 39, 0.30)    66%,
      rgba(186, 117, 23, 0.10)    84%,
      transparent                 100%
    );
    filter: blur(38px);
    mix-blend-mode: screen;
    animation: hpBeamPulse 5s ease-in-out infinite;
    will-change: transform, opacity;
  }

  /* Núcleo estreito mais brilhante */
  .hp-core {
    position: absolute;
    top: 5%;
    left: 50%;
    transform: translateX(-50%);
    width: clamp(16px, 2.5vw, 36px);
    height: 80%;
    background: linear-gradient(
      to bottom,
      transparent                 0%,
      rgba(255, 220, 80, 0.15)   15%,
      rgba(255, 210, 60, 0.55)   42%,
      rgba(245, 200, 66, 0.40)   58%,
      rgba(239, 159, 39, 0.15)   80%,
      transparent                100%
    );
    filter: blur(12px);
    mix-blend-mode: screen;
    animation: hpCoreFlicker 3.2s ease-in-out infinite alternate;
    will-change: opacity, filter;
  }

  /* Halo ambiente radial: respira lentamente */
  .hp-glow {
    position: absolute;
    inset: 0;
    background: radial-gradient(
      ellipse 50% 65% at 50% 58%,
      rgba(239, 159, 39, 0.18) 0%,
      rgba(186, 117, 23, 0.08) 38%,
      rgba(239, 159, 39, 0.03) 62%,
      transparent              75%
    );
    animation: hpGlowBreathe 6s ease-in-out infinite alternate;
    will-change: opacity;
  }

  /* ── Keyframes — apenas opacity/transform → GPU ── */
  @keyframes hpRaysRotate {
    from { transform: translateX(-50%) rotate(0deg);   }
    to   { transform: translateX(-50%) rotate(360deg); }
  }

  @keyframes hpBeamPulse {
    0%,100% { transform: translateX(-50%) scaleX(0.88); opacity: 0.72; }
    50%     { transform: translateX(-50%) scaleX(1.22); opacity: 1.00; }
  }

  @keyframes hpCoreFlicker {
    from { opacity: 0.55; }
    to   { opacity: 1.00; }
  }

  @keyframes hpGlowBreathe {
    from { opacity: 0.45; }
    to   { opacity: 1.00; }
  }
</style>

<script>
  /* ── Parallax leve — ~250 bytes minificados ────────────────
     Só desktop com hover. Carregado após idle para não
     bloquear LCP/FID. Sem imports, sem bibliotecas.
  ────────────────────────────────────────────────────────── */
  function initParallax(): void {
    const content = document.getElementById("hero-content");
    if (!content) return;
    if (!window.matchMedia("(hover: hover) and (min-width: 769px)").matches)
      return;

    // Dimensões cacheadas — evita leitura geométrica a cada mousemove
    let vw = innerWidth;
    let vh = innerHeight;
    window.addEventListener("resize", () => { vw = innerWidth; vh = innerHeight; }, { passive: true });

    // rAF throttle — garante no máximo 1 write por frame, elimina reflow forçado
    let rafId = 0;
    let lastX = 0;
    let lastY = 0;

    window.addEventListener(
      "mousemove",
      (e: MouseEvent) => {
        lastX = e.clientX;
        lastY = e.clientY;
        if (rafId) return;
        rafId = requestAnimationFrame(() => {
          const dx = lastX / vw - 0.5;
          const dy = lastY / vh - 0.5;
          content.style.transform = `translate(${-dx * 14}px,${-dy * 14}px)`;
          rafId = 0;
        });
      },
      { passive: true }
    );
  }

  // Atrasa até o browser estar ocioso → não bloqueia LCP
  if ("requestIdleCallback" in window) {
    (window as Window & { requestIdleCallback: (cb: () => void) => void })
      .requestIdleCallback(initParallax);
  } else {
    setTimeout(initParallax, 300);
  }
</script>

---
import Layout from "@/layouts/Layout.astro";
import Nav from "@/components/Nav.astro";
import Footer from "@/components/Footer.astro";

const SITE = "https://ruche.com.br";
const WA =
  "https://wa.me/5511999999999?text=Ol%C3%A1%2C%20quero%20saber%20mais%20sobre%20SEO%20aliment%C3%ADcio";

const businessTypes = [
  "Restaurante / Bar / Lanchonete",
  "Delivery / Dark Kitchen",
  "Marca de Alimentos / Bebidas",
  "Indústria Alimentícia",
  "Franquia do Setor Alimentício",
  "E-commerce de Alimentos",
  "Outro",
];
---

<Layout
  title="Contato: Fale com a Ruche | SEO Alimentício"
  description="Entre em contato com os especialistas da Ruche para descobrir como o SEO pode transformar seu negócio alimentício. Primeira consulta gratuita."
  canonical={`${SITE}/contato`}
  breadcrumbs={[{ name: "Contato", url: `${SITE}/contato` }]}
>
  <Nav />

  <main id="main-content">
    <!-- Hero -->
    <section class="page-hero" aria-labelledby="contact-hero-title">
      <div
        class="hex-pattern"
        style="position:absolute;inset:0;opacity:0.4;pointer-events:none;"
        aria-hidden="true"
      >
      </div>
      <div class="container" style="position:relative;z-index:1;">
        <p
          class="eyebrow"
          style="justify-content:center; margin-bottom:1rem;"
        >
          Vamos conversar
        </p>
        <h1 class="page-hero-title display" id="contact-hero-title">
          Transforme seu SEO
        </h1>
        <p class="page-hero-lead">
          Fale com nossos especialistas e receba uma proposta personalizada para
          seu negócio alimentício. Primeira análise gratuita.
        </p>
      </div>
    </section>

    <!-- Formulário + Info -->
    <section class="section section-dark" aria-labelledby="contact-form-title">
      <div class="container">
        <div class="contact-grid">
          <!-- Info -->
          <div class="contact-info">
            <p class="eyebrow" style="margin-bottom: 0.75rem;">
              Como podemos ajudar
            </p>
            <h2 id="contact-form-title">Fale com um especialista</h2>
            <p>
              Nossa equipe especializada no setor alimentício está pronta para
              analisar seu negócio e desenvolver uma estratégia de SEO
              customizada. Preencha o formulário ou fale direto pelo WhatsApp.
            </p>

            <ul class="contact-items">
              <li class="contact-item">
                <div
                  class="contact-item-icon"
                  aria-hidden="true"
                >
                  <svg
                    xmlns="http://www.w3.org/2000/svg"
                    width="18"
                    height="18"
                    viewBox="0 0 24 24"
                    fill="currentColor"
                  >
                    <path
                      d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"
                    ></path>
                  </svg>
                </div>
                <div>
                  <strong style="color: var(--text-primary); display: block;"
                    >WhatsApp</strong
                  >
                  <a
                    href={WA}
                    target="_blank"
                    rel="noopener noreferrer"
                    style="color: var(--amber-500);"
                  >
                    +55 (11) 9 9999-9999
                  </a>
                </div>
              </li>

              <li class="contact-item">
                <div class="contact-item-icon" aria-hidden="true">
                  <svg
                    xmlns="http://www.w3.org/2000/svg"
                    width="18"
                    height="18"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                  >
                    <path
                      d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"
                    ></path>
                    <polyline points="22,6 12,13 2,6"></polyline>
                  </svg>
                </div>
                <div>
                  <strong style="color: var(--text-primary); display: block;"
                    >E-mail</strong
                  >
                  <a
                    href="mailto:contato@ruche.com.br"
                    style="color: var(--amber-500);"
                  >
                    contato@ruche.com.br
                  </a>
                </div>
              </li>

              <li class="contact-item">
                <div class="contact-item-icon" aria-hidden="true">
                  <svg
                    xmlns="http://www.w3.org/2000/svg"
                    width="18"
                    height="18"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                  >
                    <path
                      d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"
                    ></path>
                    <circle cx="12" cy="10" r="3"></circle>
                  </svg>
                </div>
                <div>
                  <strong style="color: var(--text-primary); display: block;"
                    >Localização</strong
                  >
                  <span>São Paulo, SP, Brasil</span>
                </div>
              </li>
            </ul>

            <!-- WhatsApp direto -->
            <a
              href={WA}
              class="btn btn-amber"
              target="_blank"
              rel="noopener noreferrer"
              style="margin-top: 2rem; padding: 0.75em 1.8em;"
              aria-label="Conversar diretamente no WhatsApp"
            >
              <svg
                xmlns="http://www.w3.org/2000/svg"
                width="18"
                height="18"
                viewBox="0 0 24 24"
                fill="currentColor"
                aria-hidden="true"
              >
                <path
                  d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"
                ></path>
              </svg>
              Conversar no WhatsApp
            </a>
          </div>

          <!-- Formulário -->
          <div class="contact-form">
            <form
              method="post"
              action="#"
              novalidate
              aria-label="Formulário de contato"
              id="contact-form"
            >
              <div class="form-row">
                <div class="form-group">
                  <label class="form-label" for="name">Nome *</label>
                  <input
                    class="form-input"
                    type="text"
                    id="name"
                    name="name"
                    placeholder="Seu nome completo"
                    required
                    autocomplete="name"
                  />
                </div>
                <div class="form-group">
                  <label class="form-label" for="email">E-mail *</label>
                  <input
                    class="form-input"
                    type="email"
                    id="email"
                    name="email"
                    placeholder="seu@email.com"
                    required
                    autocomplete="email"
                  />
                </div>
              </div>

              <div class="form-row">
                <div class="form-group">
                  <label class="form-label" for="phone">Telefone / WhatsApp</label>
                  <input
                    class="form-input"
                    type="tel"
                    id="phone"
                    name="phone"
                    placeholder="(11) 9 9999-9999"
                    autocomplete="tel"
                  />
                </div>
                <div class="form-group">
                  <label class="form-label" for="business-type"
                    >Tipo de Negócio *</label
                  >
                  <select
                    class="form-select"
                    id="business-type"
                    name="business_type"
                    required
                  >
                    <option value="" disabled selected
                      >Selecione uma opção</option
                    >
                    {
                      businessTypes.map((type) => (
                        <option value={type}>{type}</option>
                      ))
                    }
                  </select>
                </div>
              </div>

              <div class="form-group">
                <label class="form-label" for="message">Mensagem *</label>
                <textarea
                  class="form-textarea"
                  id="message"
                  name="message"
                  placeholder="Conte sobre seu negócio e seus objetivos com SEO..."
                  required
                  rows="5"></textarea>
              </div>

              <button
                type="submit"
                class="btn btn-amber form-submit"
                id="form-submit"
              >
                Enviar Mensagem
              </button>
            </form>
          </div>
        </div>
      </div>
    </section>
  </main>

  <Footer />
</Layout>

<script>
  // Redirecionamento para WhatsApp ao submeter formulário
  const form = document.getElementById("contact-form") as HTMLFormElement | null;

  form?.addEventListener("submit", (e) => {
    e.preventDefault();

    const name = (form.querySelector("#name") as HTMLInputElement)?.value ?? "";
    const email = (form.querySelector("#email") as HTMLInputElement)?.value ?? "";
    const businessType =
      (form.querySelector("#business-type") as HTMLSelectElement)?.value ?? "";
    const message =
      (form.querySelector("#message") as HTMLTextAreaElement)?.value ?? "";

    const text = encodeURIComponent(
      `Olá! Meu nome é ${name}.\nE-mail: ${email}\nTipo de negócio: ${businessType}\n\n${message}`
    );

    window.open(`https://wa.me/5511999999999?text=${text}`, "_blank");
  });
</script>

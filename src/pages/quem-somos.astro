---
import Layout from "@/layouts/Layout.astro";
import Nav from "@/components/Nav.astro";
import CTASection from "@/components/CTASection.astro";
import Footer from "@/components/Footer.astro";

const SITE = "https://ruche.com.br";

const values = [
  {
    title: "Especialização Total",
    text: "100% focados no setor alimentício. Conhecemos a linguagem, os desafios e as oportunidades do seu mercado.",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>`,
  },
  {
    title: "Transparência Absoluta",
    text: "Relatórios mensais claros com métricas reais. Você sabe exatamente onde está investindo e o que está retornando.",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>`,
  },
  {
    title: "Resultados Comprovados",
    text: "Metodologia baseada em dados com histórico de 8+ anos de crescimento orgânico mensurável para clientes do setor.",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="22 7 13.5 15.5 8.5 10.5 2 17"/><polyline points="16 7 22 7 22 13"/></svg>`,
  },
  {
    title: "Parceria de Longo Prazo",
    text: "Não somos um serviço pontual. Somos parceiros estratégicos comprometidos com o crescimento sustentável do seu negócio.",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>`,
  },
];
---

<Layout
  title="Quem Somos — Ruche, Agência de SEO Alimentício"
  description="Conheça a Ruche: a agência de SEO especializada exclusivamente no setor alimentício. Nossa missão, valores e a equipe por trás dos resultados."
  canonical={`${SITE}/quem-somos`}
  breadcrumbs={[{ name: "Quem Somos", url: `${SITE}/quem-somos` }]}
>
  <Nav />

  <main id="main-content">
    <!-- Hero da página -->
    <section
      class="page-hero hex-pattern"
      aria-labelledby="about-hero-title"
    >
      <div
        class="hex-pattern"
        style="position:absolute;inset:0;opacity:0.5;pointer-events:none;"
        aria-hidden="true"
      >
      </div>
      <div class="container" style="position:relative;z-index:1;">
        <p class="eyebrow" style="justify-content:center; margin-bottom:1rem;">
          Nossa história
        </p>
        <h1 class="page-hero-title display" id="about-hero-title">
          Somos a Ruche
        </h1>
        <p class="page-hero-lead">
          A agência de SEO que fala o idioma do setor alimentício. Nascemos da
          paixão por gastronomia e da obsessão por resultados orgânicos.
        </p>
      </div>
    </section>

    <!-- Missão -->
    <section class="section section-dark" aria-labelledby="mission-title">
      <div class="container">
        <div class="about-grid">
          <div class="about-text">
            <p class="eyebrow">Nossa missão</p>
            <h2 id="mission-title">
              Colocar negócios alimentícios no topo do Google
            </h2>
            <p>
              A Ruche nasceu de uma constatação simples: o setor alimentício
              merecia uma agência que realmente entendesse seus desafios
              únicos. Sazonalidade, regulação, localização, experiência do
              consumidor — tudo isso impacta o SEO de restaurantes e marcas de
              alimentos de formas que agências generalistas simplesmente não
              conseguem endereçar.
            </p>
            <p>
              Com mais de 8 anos de experiência exclusiva no setor, nossa
              equipe desenvolveu metodologias, banco de dados de palavras-chave
              e rede de links específicos para o universo alimentício brasileiro.
            </p>
            <p>
              Hoje, atendemos mais de 120 clientes — de restaurantes locais a
              grandes indústrias de alimentos — com uma taxa de renovação de
              contratos acima de 90%.
            </p>
          </div>
          <div
            style="background: linear-gradient(135deg, var(--dark-800) 0%, var(--dark-700) 100%); border-radius: var(--radius-xl); border: 1px solid rgba(239,159,39,0.12); min-height: 360px; display: flex; align-items: center; justify-content: center;"
            aria-hidden="true"
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="80"
              height="90"
              viewBox="0 0 28 32"
              fill="none"
              aria-hidden="true"
              style="opacity: 0.3;"
            >
              <polygon
                points="14,1.5 27,8.5 27,23.5 14,30.5 1,23.5 1,8.5"
                fill="#EF9F27"
              ></polygon>
              <text
                x="14"
                y="21"
                text-anchor="middle"
                font-family="Arial Black,sans-serif"
                font-size="13"
                font-weight="900"
                fill="#040200"
              >R</text>
            </svg>
          </div>
        </div>
      </div>
    </section>

    <!-- Valores -->
    <section
      class="section section-darker"
      aria-labelledby="values-title"
    >
      <div class="container">
        <header class="section-header">
          <p class="eyebrow">O que nos guia</p>
          <h2 class="section-title display" id="values-title">
            Nossos valores
          </h2>
        </header>

        <div class="values-grid">
          {
            values.map((v) => (
              <div class="value-pill">
                <div
                  class="value-pill-icon"
                  aria-hidden="true"
                  set:html={v.icon}
                />
                <div>
                  <p class="value-pill-title">{v.title}</p>
                  <p class="value-pill-text">{v.text}</p>
                </div>
              </div>
            ))
          }
        </div>
      </div>
    </section>

    <!-- Métricas rápidas -->
    <section class="section section-dark" aria-labelledby="stats-title">
      <div class="container">
        <header class="section-header">
          <p class="eyebrow">Em números</p>
          <h2 class="section-title display" id="stats-title">
            Resultados que falam
          </h2>
        </header>

        <div
          class="metrics-grid"
          role="list"
          aria-label="Estatísticas da Ruche"
        >
          {
            [
              { number: "120+", label: "Clientes no setor alimentício" },
              { number: "8+", label: "Anos de experiência exclusiva" },
              { number: "+180%", label: "Crescimento médio de tráfego" },
              { number: "90%+", label: "Taxa de renovação de contratos" },
            ].map((m) => (
              <div class="metric-item" role="listitem">
                <p class="metric-number display">{m.number}</p>
                <p class="metric-label">{m.label}</p>
              </div>
            ))
          }
        </div>
      </div>
    </section>

    <CTASection />
  </main>

  <Footer />
</Layout>

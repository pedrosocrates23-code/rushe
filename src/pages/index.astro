---
import Layout from "@/layouts/Layout.astro";
import Nav from "@/components/Nav.astro";
import Hero from "@/components/Hero.astro";
import ValueSection from "@/components/ValueSection.astro";
import ServicesSection from "@/components/ServicesSection.astro";
import CTASection from "@/components/CTASection.astro";
import Footer from "@/components/Footer.astro";
---

<Layout
  title="Ruche: SEO para o Setor Alimentício | Restaurantes e Marcas"
  description="Agência de SEO especializada em restaurantes, marcas de alimentos e indústria alimentícia. Aumente seu tráfego orgânico e conquiste mais clientes com estratégias comprovadas."
  canonical="https://ruche.com.br/"
  includeFaq={true}
>
  <Nav />

  <main id="main-content">
    <Hero />
    <ValueSection />
    <ServicesSection />
    <CTASection />
  </main>

  <Footer />
</Layout>
